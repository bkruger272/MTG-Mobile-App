{
  "expo": {
    "name": "MTG-Mobile-App",
    "slug": "MTG-Mobile-App",
    "scheme": "mtglookupapp",
    "version": "1.0.0",
    "android": {
      "package": "com.bkruger.MTGLookupApp",
      "versionCode": 7,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      }
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow MTG Scanner to use the camera to identify card names.",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a97ae721-5556-4d1a-bcd1-2885b45feb7c"
      }
    }
  }
}
